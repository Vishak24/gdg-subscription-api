{
    "info": {
        "_postman_id": "gdg-subscription-api-v1",
        "name": "GDG Subscription API",
        "description": "Production-grade Subscription-Based Content API. Import this collection and set the `baseUrl` and `bearerToken` environment variables.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000/api",
            "type": "string"
        },
        {
            "key": "bearerToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "refreshToken",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.success && json.data.tokens) {",
                                    "  pm.collectionVariables.set('bearerToken', json.data.tokens.accessToken);",
                                    "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/register",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"TestPass1!\"\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.success && json.data.tokens) {",
                                    "  pm.collectionVariables.set('bearerToken', json.data.tokens.accessToken);",
                                    "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"TestPass1!\"\n}"
                        }
                    }
                },
                {
                    "name": "Login as Admin",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.success && json.data.tokens) {",
                                    "  pm.collectionVariables.set('bearerToken', json.data.tokens.accessToken);",
                                    "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@gdg.com\",\n  \"password\": \"Admin@123\"\n}"
                        }
                    }
                },
                {
                    "name": "Login as Premium User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.success && json.data.tokens) {",
                                    "  pm.collectionVariables.set('bearerToken', json.data.tokens.accessToken);",
                                    "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"premium@gdg.com\",\n  \"password\": \"Test@123\"\n}"
                        }
                    }
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.success && json.data.accessToken) {",
                                    "  pm.collectionVariables.set('bearerToken', json.data.accessToken);",
                                    "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/refresh",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Me",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/me"
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/auth/logout",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Subscriptions",
            "item": [
                {
                    "name": "Get Subscription Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/subscriptions/status"
                    }
                },
                {
                    "name": "Upgrade to Premium",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/subscriptions/upgrade"
                    }
                },
                {
                    "name": "Get Subscription History",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/subscriptions/history"
                    }
                }
            ]
        },
        {
            "name": "Content",
            "item": [
                {
                    "name": "Get Free Content",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/content/free"
                    }
                },
                {
                    "name": "Get Premium Content (requires PREMIUM tier)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/content/premium"
                    }
                }
            ]
        },
        {
            "name": "Activity",
            "item": [
                {
                    "name": "Get My Activity",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/activity?page=1&limit=20",
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Admin (ADMIN role required)",
            "item": [
                {
                    "name": "Get All Logs",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/logs?page=1&limit=20",
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                },
                                {
                                    "key": "action",
                                    "value": "",
                                    "disabled": true
                                },
                                {
                                    "key": "userId",
                                    "value": "",
                                    "disabled": true
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get All Users",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/users?page=1&limit=20",
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Download Monthly CSV Report",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearerToken}}"
                            }
                        ],
                        "url": "{{baseUrl}}/admin/report/csv"
                    }
                }
            ]
        },
        {
            "name": "Health Check",
            "item": [
                {
                    "name": "Health",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:3000/health"
                    }
                }
            ]
        }
    ]
}